{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AKP Law Schema",
  "description": "Definition of a valid law in the Açık Kamu Protokolü",
  "type": "object",
  "properties": {
    "law_id": { "type": "string", "pattern": "^AKP-LAW-[0-9]{5}$" },
    "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "scope": { 
      "type": "string",
      "enum": ["HUMAN_DEVELOPMENT", "INFRASTRUCTURE", "ECONOMY", "JUSTICE"]
    },
    "simulation_results": {
      "type": "object",
      "properties": {
        "success_rate": { "type": "number", "minimum": 0, "maximum": 100 },
        "environmental_impact": { "type": "number" },
        "economic_efficiency": { "type": "number" }
      },
      "required": ["success_rate"]
    },
    "expiration_date": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["PROPOSED", "SIMULATING", "ACTIVE", "DEPRECATED", "ARCHIVED"]
    }
  },
  "required": ["law_id", "version", "title", "scope", "status"]
}
